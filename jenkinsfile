pipeline {
    agent any

    environment {
        FRONTEND_IMAGE = "frontend-app"
        BACKEND_IMAGE  = "backend-app"
        DOCKER_USER    = "syedumer98488"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'master',
                    credentialsId: 'github',
                    url: 'https://github.com/syedume/nodejs-app.git'
            }
        }

        stage('Build Frontend Image') {
            steps {
                sh "docker build -t $FRONTEND_IMAGE ./frontend"
            }
        }

        stage('Build Backend Image') {
            steps {
                sh "docker build -t $BACKEND_IMAGE ./backend"
            }
        }

        stage('Run Containers') {
            steps {
                sh '''
                docker rm -f frontend || true
                docker rm -f backend || true

                docker run -d -p 3000:80 --name frontend frontend-app
                docker run -d -p 5000:5000 --name backend backend-app
                '''
            }
        }

        stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DH_USER',
                    passwordVariable: 'DH_PASS'
                )]) {
                    sh 'echo $DH_PASS | docker login -u $DH_USER --password-stdin'
                }
            }
        }

        stage('Push Frontend Image') {
            steps {
                sh '''
                docker tag frontend-app $DOCKER_USER/frontend-app:$BUILD_NUMBER
                docker push $DOCKER_USER/frontend-app:$BUILD_NUMBER
                '''
            }
        }

        stage('Push Backend Image') {
            steps {
                sh '''
                docker tag backend-app $DOCKER_USER/backend-app:$BUILD_NUMBER
                docker push $DOCKER_USER/backend-app:$BUILD_NUMBER
                '''
            }
        }
    }
}